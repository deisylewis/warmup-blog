# API Credentials with Client Names
OPENAI_API_KEY=your_openai_api_key_here

# Client 1 APIs (replace "client1" with actual client name)
CLIENT1_NAME=client1
CLIENT1_RB2B_API_KEY=your_rb2b_api_key_here
CLIENT1_RB2B_API_URL=https://api.rb2b.com/v1/exports
CLIENT1_HEYREACH_API_KEY=your_heyreach_api_key_here
CLIENT1_HEYREACH_API_URL=https://api.heyreach.io/v1/exports
CLIENT1_INSTANTLY_API_KEY=your_instantly_api_key_here
CLIENT1_INSTANTLY_API_URL=https://api.instantly.ai/v1/exports

# Client 2 APIs (add more clients as needed)
CLIENT2_NAME=client2
CLIENT2_RB2B_API_KEY=your_rb2b_api_key_here
CLIENT2_RB2B_API_URL=https://api.rb2b.com/v1/exports
CLIENT2_HEYREACH_API_KEY=your_heyreach_api_key_here
CLIENT2_HEYREACH_API_URL=https://api.heyreach.io/v1/exports
CLIENT2_INSTANTLY_API_KEY=your_instantly_api_key_here
CLIENT2_INSTANTLY_API_URL=https://api.instantly.ai/v1/exports

# Add more clients by following the pattern:
# CLIENT3_NAME=client3
# CLIENT3_RB2B_API_KEY=...
# etc.

# File paths
DOWNLOAD_DIR=./downloads
PROCESSED_DIR=./processed

# OpenAI settings
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000